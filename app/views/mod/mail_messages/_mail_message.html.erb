<div class="message" id="<%= dom_id mod_mail_message %>">
  <div class="details">
    <div class="byline">
      <% if mod_mail_message.user %>
        <%= inline_avatar_for @user, mod_mail_message.user %> <%= styled_user_link mod_mail_message.user %>
      <% else %>
        <%= mod_mail_message.user.username %>
      <% end %>
      <a href="mod/mail_messages/<%= mod_mail_message.id %>"><%= how_long_ago_label(mod_mail_message.created_at) %></a>
    </div>
    <div class="message-body">
      <%= raw mod_mail_message.linkified_message %>
    </div>
  </div>
</div>
